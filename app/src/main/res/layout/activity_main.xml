<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/safepal_bg" android:orientation="vertical">

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
    <LinearLayout android:orientation="vertical" android:paddingHorizontal="16dp"
        android:paddingTop="24dp" android:layout_width="match_parent" android:layout_height="wrap_content">

        <LinearLayout android:gravity="center" android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="Cân bằng" android:textColor="#B0B0B0" android:textSize="15sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <ImageView android:id="@+id/btnEye" android:layout_marginStart="6dp"
                android:src="@android:drawable/ic_menu_view" android:tint="#B0B0B0"
                android:layout_width="22dp" android:layout_height="22dp"/>
        </LinearLayout>

        <TextView android:id="@+id/tvUsdBalance" android:text="$0.00"
            android:textColor="#FFFFFF" android:textSize="48sp" android:textStyle="bold"
            android:gravity="center" android:layout_marginTop="8dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/tvBtcBalance" android:text="0.00000 BTC"
            android:textColor="#B0B0B0" android:textSize="20sp"
            android:gravity="center" android:layout_marginTop="2dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/tvTodayChange" android:text="Hôm nay +$0.00 ▲0.00%"
            android:textColor="#00C076" android:textSize="15sp"
            android:gravity="center" android:layout_marginTop="6dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <LinearLayout android:orientation="horizontal" android:gravity="center"
            android:layout_marginTop="28dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:id="@+id/btnSend" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content">
                <ImageView android:background="@drawable/bg_circle_dark" android:padding="16dp" android:src="@android:drawable/arrow_up_float" android:tint="#FFF" android:layout_width="60dp" android:layout_height="60dp"/>
                <TextView android:text="Gửi" android:textColor="#B0B0B0" android:textSize="13sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/btnReceive" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content">
                <ImageView android:background="@drawable/bg_circle_dark" android:padding="16dp" android:src="@android:drawable/arrow_down_float" android:tint="#FFF" android:layout_width="60dp" android:layout_height="60dp"/>
                <TextView android:text="Nhận" android:textColor="#B0B0B0" android:textSize="13sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content">
                <ImageView android:background="@drawable/bg_circle_dark" android:padding="16dp" android:src="@android:drawable/ic_menu_agenda" android:tint="#FFF" android:layout_width="60dp" android:layout_height="60dp"/>
                <TextView android:text="Mua" android:textColor="#B0B0B0" android:textSize="13sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content">
                <ImageView android:background="@drawable/bg_circle_dark" android:padding="16dp" android:src="@android:drawable/ic_menu_compass" android:tint="#FFF" android:layout_width="60dp" android:layout_height="60dp"/>
                <TextView android:text="Gas Station" android:textColor="#B0B0B0" android:textSize="12sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content">
                <ImageView android:background="@drawable/bg_circle_dark" android:padding="16dp" android:src="@android:drawable/ic_menu_more" android:tint="#FFF" android:layout_width="60dp" android:layout_height="60dp"/>
                <TextView android:text="Thêm" android:textColor="#B0B0B0" android:textSize="13sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:layout_marginTop="24dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:background="#1A1F2E" android:gravity="center_vertical"
                android:padding="12dp" android:layout_weight="1"
                android:layout_width="0dp" android:layout_height="48dp">
                <ImageView android:src="@android:drawable/ic_menu_search" android:tint="#9E9E9E" android:layout_width="20dp" android:layout_height="20dp"/>
                <TextView android:text="Tìm" android:textColor="#9E9E9E" android:layout_marginStart="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:id="@+id/cardBtc" android:background="#1A1F2E"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="16dp" android:layout_marginTop="16dp"
            android:layout_width="match_parent" android:layout_height="72dp">
            <ImageView android:layout_width="40dp" android:layout_height="40dp"
                android:src="@android:drawable/star_big_on" android:tint="#F7931A"/>
            <LinearLayout android:orientation="vertical" android:layout_marginStart="12dp"
                android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                <TextView android:text="BTC (Bitcoin)" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <TextView android:id="@+id/tvBtcPrice" android:text="$0.00"
                        android:textColor="#9E9E9E" android:textSize="14sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvBtcChange" android:text=" +0.00%"
                        android:textColor="#00C076" android:textSize="14sp" android:layout_marginStart="6dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:orientation="vertical" android:gravity="end"
                android:layout_width="wrap_content" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvBtcAmount" android:text="0.00000"
                    android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvBtcUsd" android:text="$0.00"
                    android:textColor="#9E9E9E" android:textSize="14sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <TextView android:text="⟲ Quản lí Coin" android:textColor="#B0B0B0"
            android:textSize="15sp" android:gravity="center"
            android:layout_marginTop="20dp" android:layout_marginBottom="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

    </LinearLayout>
    </ScrollView>
    <include layout="@layout/layout_bottom_nav"/>
</LinearLayout>