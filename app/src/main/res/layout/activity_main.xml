<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:padding="24dp"
    android:layout_width="match_parent" android:layout_height="match_parent">
    <Button android:id="@+id/btnCreate" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Tạo ví BTC mới"/>
    <EditText android:id="@+id/edtMnemonic" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Dán 12 từ để khôi phục" android:layout_marginTop="24dp"/>
    <Button android:id="@+id/btnImport" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Khôi phục"/>
</LinearLayout>