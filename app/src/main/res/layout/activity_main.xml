<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0B0E14">

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_above="@+id/bottomNav" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout android:layout_width="match_parent" android:layout_height="60dp"
                android:paddingHorizontal="20dp">
                <ImageView android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_centerVertical="true" android:background="@drawable/circle_purple"
                    android:padding="6dp" android:src="@android:drawable/ic_menu_myplaces"/>
                <TextView android:layout_centerInParent="true" android:text="Ví của tôi"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_alignParentEnd="true" android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_popup_sync"/>
            </RelativeLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="220dp"
                android:layout_margin="16dp" android:background="@drawable/bg_card_gradient"
                android:gravity="center" android:orientation="vertical" android:padding="24dp">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:text="Tổng tài sản" android:textColor="#8A8F98"
                        android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:layout_marginStart="8dp" android:src="@android:drawable/ic_menu_view"/>
                </LinearLayout>
                <TextView android:id="@+id/tvUsd" android:layout_marginTop="12dp"
                    android:text="$0.00" android:textColor="#FFFFFF" android:textSize="38sp"
                    android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvBalance" android:layout_marginTop="4dp"
                    android:text="≈ 0 BTC" android:textColor="#8A8F98" android:textSize="15sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvAddress" android:layout_marginTop="18dp"
                    android:background="#141926" android:drawableStart="@android:drawable/ic_menu_edit"
                    android:drawablePadding="6dp" android:paddingHorizontal="14dp" android:paddingVertical="7dp"
                    android:text="1..." android:textColor="#8A8F98" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:gravity="center" android:orientation="horizontal"
                android:paddingHorizontal="28dp">
                <LinearLayout android:id="@+id/btnSend" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:gravity="center" android:orientation="vertical">
                    <FrameLayout android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/circle_purple">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_gravity="center" android:src="@android:drawable/ic_menu_send"/>
                    </FrameLayout>
                    <TextView android:layout_marginTop="8dp" android:text="Gửi"
                        android:textColor="#FFFFFF" android:textSize="13sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/btnReceive" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:gravity="center" android:orientation="vertical">
                    <FrameLayout android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/circle_purple">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_gravity="center" android:src="@android:drawable/ic_menu_revert"/>
                    </FrameLayout>
                    <TextView android:layout_marginTop="8dp" android:text="Nhận"
                        android:textColor="#FFFFFF" android:textSize="13sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/btnBuy" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:gravity="center" android:orientation="vertical">
                    <FrameLayout android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/circle_blue">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_gravity="center" android:src="@android:drawable/ic_input_add"/>
                    </FrameLayout>
                    <TextView android:layout_marginTop="8dp" android:text="Mua"
                        android:textColor="#FFFFFF" android:textSize="13sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/btnSwap" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:gravity="center" android:orientation="vertical">
                    <FrameLayout android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/circle_blue">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_gravity="center" android:src="@android:drawable/ic_menu_share"/>
                    </FrameLayout>
                    <TextView android:layout_marginTop="8dp" android:text="Swap"
                        android:textColor="#FFFFFF" android:textSize="13sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="28dp" android:orientation="horizontal"
                android:paddingHorizontal="20dp">
                <TextView android:text="Token" android:textColor="#5B4CF0"
                    android:textSize="16sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:layout_marginStart="24dp" android:text="NFT"
                    android:textColor="#8A8F98" android:textSize="16sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="72dp"
                android:layout_marginHorizontal="16dp" android:layout_marginTop="12dp"
                android:background="#141926" android:gravity="center_vertical"
                android:orientation="horizontal" android:paddingHorizontal="16dp">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/circle_purple" android:padding="8dp"
                    android:src="@android:drawable/btn_star_big_on"/>
                <LinearLayout android:layout_marginStart="12dp" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:text="Bitcoin" android:textColor="#FFFFFF"
                        android:textSize="16sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="BTC" android:textColor="#8A8F98"
                        android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:gravity="end" android:orientation="vertical"
                    android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <TextView android:id="@+id/tvBtcAmount" android:text="0 BTC"
                        android:textColor="#FFFFFF" android:textSize="16sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="$0.00" android:textColor="#8A8F98"
                        android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout android:id="@+id/bottomNav" android:layout_alignParentBottom="true"
        android:layout_width="match_parent" android:layout_height="64dp"
        android:background="#141926" android:gravity="center" android:orientation="horizontal"
        android:paddingHorizontal="12dp">
        <LinearLayout android:id="@+id/navWallet" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_compass" android:tint="#5B4CF0"/>
            <TextView android:text="Ví" android:textColor="#5B4CF0" android:textSize="11sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navMarket" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_sort_by_size" android:tint="#8A8F98"/>
            <TextView android:text="Thị trường" android:textColor="#8A8F98" android:textSize="11sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navDapp" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_directions" android:tint="#8A8F98"/>
            <TextView android:text="DApp" android:textColor="#8A8F98" android:textSize="11sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navSwap" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_rotate" android:tint="#8A8F98"/>
            <TextView android:text="Swap" android:textColor="#8A8F98" android:textSize="11sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navSettings" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_preferences" android:tint="#8A8F98"/>
            <TextView android:text="Cài đặt" android:textColor="#8A8F98" android:textSize="11sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>