<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/safepal_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tạo mật khẩu"
        android:textColor="@color/safepal_text"
        android:textSize="20sp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Mật khẩu phải ≥8 ký tự"
        android:textColor="@color/safepal_gray"
        android:textSize="13sp"/>

    <EditText
        android:id="@+id/etPass1"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:background="@color/safepal_card"
        android:hint="Nhập mật khẩu"
        android:inputType="textPassword"
        android:padding="16dp"
        android:textColor="@color/safepal_text"
        android:textColorHint="@color/safepal_gray"/>

    <EditText
        android:id="@+id/etPass2"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@color/safepal_card"
        android:hint="Nhập lại mật khẩu"
        android:inputType="textPassword"
        android:padding="16dp"
        android:textColor="@color/safepal_text"
        android:textColorHint="@color/safepal_gray"/>

    <Button
        android:id="@+id/btnSetPass"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/safepal_purple"
        android:text="Hoàn tất"
        android:textAllCaps="false"
        android:textSize="16sp"/>
</LinearLayout>