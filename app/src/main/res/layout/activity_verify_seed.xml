<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/safepal_bg" android:padding="24dp"
    android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">

    <TextView android:text="Xác nhận cụm từ" android:textSize="22sp"
        android:textStyle="bold" android:textColor="@color/safepal_text"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <EditText android:id="@+id/etVerify" android:layout_marginTop="24dp"
        android:hint="Nhập lại 12 từ" android:background="@color/safepal_card"
        android:padding="16dp" android:textColor="@color/safepal_text"
        android:layout_width="match_parent" android:layout_height="120dp"/>

    <Button android:id="@+id/btnVerify" android:layout_marginTop="24dp"
        android:text="Xác nhận" android:backgroundTint="@color/safepal_purple"
        android:layout_width="match_parent" android:layout_height="56dp"/>
</LinearLayout>