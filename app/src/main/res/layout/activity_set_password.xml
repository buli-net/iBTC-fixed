<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/safepal_bg" android:orientation="vertical" android:padding="24dp">
    <TextView android:text="Tạo mật khẩu" android:textSize="22sp"
        android:textStyle="bold" android:textColor="@color/safepal_text"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="Mật khẩu dùng để mở khóa ví" android:textColor="@color/safepal_gray"
        android:layout_marginTop="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/etPass1" android:layout_marginTop="24dp"
        android:hint="Nhập mật khẩu (tối thiểu 6 ký tự)" android:inputType="textPassword"
        android:background="@color/safepal_card" android:padding="16dp"
        android:textColor="@color/safepal_text" android:textColorHint="@color/safepal_gray"
        android:layout_width="match_parent" android:layout_height="56dp"/>
    <EditText android:id="@+id/etPass2" android:layout_marginTop="12dp"
        android:hint="Xác nhận mật khẩu" android:inputType="textPassword"
        android:background="@color/safepal_card" android:padding="16dp"
        android:textColor="@color/safepal_text" android:textColorHint="@color/safepal_gray"
        android:layout_width="match_parent" android:layout_height="56dp"/>
    <Button android:id="@+id/btnSetPass" android:layout_marginTop="24dp"
        android:text="Hoàn tất" android:backgroundTint="@color/safepal_purple"
        android:textAllCaps="false" android:layout_width="match_parent" android:layout_height="56dp"/>
</LinearLayout>