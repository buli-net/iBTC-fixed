<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/safepal_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Địa chỉ ví Bitcoin của bạn"
        android:textColor="@color/safepal_gray"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvReceiveAddr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@color/safepal_card"
        android:padding="16dp"
        android:text="bc1q..."
        android:textColor="@color/safepal_text"
        android:textIsSelectable="true"
        android:textSize="15sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Chỉ gửi BTC (Bitcoin) đến địa chỉ này"
        android:textColor="@color/safepal_purple"
        android:textSize="12sp" />
</LinearLayout>