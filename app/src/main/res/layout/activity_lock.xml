<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/safepal_bg" android:gravity="center"
    android:orientation="vertical" android:padding="32dp">
    <ImageView android:layout_width="64dp" android:layout_height="64dp"
        android:src="@android:drawable/ic_lock_lock" android:tint="@color/safepal_purple"/>
    <TextView android:layout_marginTop="16dp" android:text="Nhập mật khẩu"
        android:textColor="@color/safepal_text" android:textSize="20sp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/etPass" android:layout_marginTop="24dp"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@color/safepal_card2" android:hint="Mật khẩu"
        android:inputType="textPassword" android:padding="16dp"
        android:textColor="@color/safepal_text" android:textColorHint="@color/safepal_gray"/>
    <Button android:id="@+id/btnUnlock" android:layout_marginTop="16dp"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="@color/safepal_purple" android:text="Mở khóa"/>
</LinearLayout>