<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000" android:orientation="vertical">

    <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0F141E" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:id="@+id/btnBack" android:layout_width="24dp" android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert" android:tint="#B0B0B0"
            android:layout_centerVertical="true"/>
        <TextView android:text="Cài đặt ví" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
            android:layout_centerInParent="true"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </RelativeLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">

            <LinearLayout android:id="@+id/itemBackupSeed" android:orientation="horizontal" android:gravity="center_vertical"
                android:background="#0F141E" android:padding="16dp" android:layout_marginTop="16dp"
                android:layout_width="match_parent" android:layout_height="56dp">
                <ImageView android:src="@android:drawable/ic_menu_save" android:tint="#7B3FF2"
                    android:layout_width="24dp" android:layout_height="24dp"/>
                <TextView android:text="Sao lưu seed phrase" android:textColor="#B0B0B0" android:textSize="16sp"
                    android:layout_marginStart="16dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/itemChangePass" android:orientation="horizontal" android:gravity="center_vertical"
                android:background="#0F141E" android:padding="16dp" android:layout_marginTop="8dp"
                android:layout_width="match_parent" android:layout_height="56dp">
                <ImageView android:src="@android:drawable/ic_lock_lock" android:tint="#7B3FF2"
                    android:layout_width="24dp" android:layout_height="24dp"/>
                <TextView android:text="Đổi mật khẩu" android:textColor="#B0B0B0" android:textSize="16sp"
                    android:layout_marginStart="16dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/itemDelete" android:orientation="horizontal" android:gravity="center_vertical"
                android:background="#0F141E" android:padding="16dp" android:layout_marginTop="8dp"
                android:layout_width="match_parent" android:layout_height="56dp">
                <ImageView android:src="@android:drawable/ic_delete" android:tint="#FF4444"
                    android:layout_width="24dp" android:layout_height="24dp"/>
                <TextView android:text="Xóa ví" android:textColor="#FF4444" android:textSize="16sp"
                    android:layout_marginStart="16dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/layout_bottom_nav"/>

</LinearLayout>