<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/safepal_bg" android:orientation="vertical">

    <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#141926" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:id="@+id/btnBack" android:layout_width="24dp" android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert" android:tint="#FFFFFF"/>
        <TextView android:layout_centerInParent="true" android:text="Cài đặt ví"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </RelativeLayout>

    <LinearLayout android:id="@+id/itemBackupSeed" android:layout_width="match_parent"
        android:layout_height="56dp" android:gravity="center_vertical" android:orientation="horizontal"
        android:paddingHorizontal="16dp" android:background="#1A1F2E" android:layout_marginTop="16dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_agenda" android:tint="#7B5CFA"/>
        <TextView android:layout_marginStart="12dp" android:text="Sao lưu seed phrase"
            android:textColor="#FFFFFF" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/itemChangePass" android:layout_width="match_parent"
        android:layout_height="56dp" android:gravity="center_vertical" android:orientation="horizontal"
        android:paddingHorizontal="16dp" android:background="#1A1F2E" android:layout_marginTop="8dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@android:drawable/ic_lock_lock" android:tint="#7B5CFA"/>
        <TextView android:layout_marginStart="12dp" android:text="Đổi mật khẩu"
            android:textColor="#FFFFFF" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/itemDelete" android:layout_width="match_parent"
        android:layout_height="56dp" android:gravity="center_vertical" android:orientation="horizontal"
        android:paddingHorizontal="16dp" android:background="#1A1F2E" android:layout_marginTop="8dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@android:drawable/ic_delete" android:tint="#FF4444"/>
        <TextView android:layout_marginStart="12dp" android:text="Xóa ví"
            android:textColor="#FF4444" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>