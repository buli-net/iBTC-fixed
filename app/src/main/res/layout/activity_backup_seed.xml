<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/safepal_bg" android:orientation="vertical" android:padding="24dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Sao lưu cụm từ khôi phục" android:textColor="@color/safepal_text"
        android:textSize="22sp" android:textStyle="bold"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:text="Viết ra giấy theo đúng thứ tự. Đây là chìa khóa ví của bạn."
        android:textColor="@color/safepal_gray"/>

    <TextView android:id="@+id/tvSeed"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="32dp" android:background="@color/safepal_card"
        android:padding="20dp" android:textColor="@color/safepal_text"
        android:textSize="18sp" android:lineSpacingExtra="8dp"/>

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <Button android:id="@+id/btnNext"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="@color/safepal_purple"
        android:text="Tôi đã ghi lại" android:textAllCaps="false"/>
</LinearLayout>