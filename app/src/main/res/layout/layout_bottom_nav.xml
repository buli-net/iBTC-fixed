<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_alignParentBottom="true"
    android:background="#141926"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp">

    <LinearLayout android:id="@+id/navWallet" android:layout_weight="1"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/icWallet" android:layout_width="24dp" android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_compass"/>
        <TextView android:id="@+id/tvWallet" android:text="Ví" android:textSize="11sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navMarket" android:layout_weight="1"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/icMarket" android:layout_width="24dp" android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_sort_by_size"/>
        <TextView android:id="@+id/tvMarket" android:text="Thị trường" android:textSize="11sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navDapp" android:layout_weight="1"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/icDapp" android:layout_width="24dp" android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_directions"/>
        <TextView android:id="@+id/tvDapp" android:text="DApp" android:textSize="11sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navSwap" android:layout_weight="1"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/icSwap" android:layout_width="24dp" android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_rotate"/>
        <TextView android:id="@+id/tvSwap" android:text="Swap" android:textSize="11sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navSettings" android:layout_weight="1"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/icSettings" android:layout_width="24dp" android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_preferences"/>
        <TextView android:id="@+id/tvSettings" android:text="Cài đặt" android:textSize="11sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>