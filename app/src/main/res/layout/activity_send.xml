<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/safepal_bg">
<LinearLayout android:orientation="vertical" android:padding="16dp"
    android:layout_width="match_parent" android:layout_height="wrap_content">

    <ImageView android:id="@+id/btnBack" android:layout_width="24dp" android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_revert" android:tint="#FFFFFF"/>

    <TextView android:text="Gửi BTC" android:textColor="#FFFFFF" android:textSize="20sp"
        android:textStyle="bold" android:layout_marginTop="16dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <TextView android:text="Địa chỉ nhận" android:textColor="#9E9E9E" android:layout_marginTop="24dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <EditText android:id="@+id/etAddress" android:layout_weight="1"
            android:background="#1A1F2E" android:textColor="#FFFFFF" android:hint="bc1..."
            android:padding="12dp" android:layout_height="48dp" android:layout_width="0dp"/>
        <ImageView android:id="@+id/btnScan" android:layout_width="48dp" android:layout_height="48dp"
            android:background="#1A1F2E" android:padding="12dp"
            android:src="@android:drawable/ic_menu_camera" android:tint="#7B5CFA"/>
    </LinearLayout>

    <TextView android:text="Số lượng" android:textColor="#9E9E9E" android:layout_marginTop="16dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/etAmount" android:background="#1A1F2E" android:textColor="#FFFFFF"
        android:hint="0.0" android:inputType="numberDecimal" android:padding="12dp"
        android:layout_width="match_parent" android:layout_height="48dp"/>

    <TextView android:text="Phí mạng (real-time)" android:textColor="#9E9E9E"
        android:layout_marginTop="16dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <RadioGroup android:id="@+id/rgFee" android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RadioButton android:id="@+id/rbSlow" android:text="Chậm" android:textColor="#FFFFFF"/>
        <RadioButton android:id="@+id/rbNormal" android:text="Thường" android:checked="true"
            android:textColor="#FFFFFF"/>
        <RadioButton android:id="@+id/rbFast" android:text="Nhanh" android:textColor="#FFFFFF"/>
        <RadioButton android:id="@+id/rbCustom" android:text="Tùy chỉnh" android:textColor="#FFFFFF"/>
    </RadioGroup>

    <EditText android:id="@+id/etCustomFee" android:visibility="gone" android:hint="nhập sat/vB"
        android:inputType="number" android:background="#1A1F2E" android:textColor="#FFFFFF"
        android:padding="12dp" android:layout_width="match_parent" android:layout_height="48dp"/>

    <TextView android:id="@+id/tvFeeInfo" android:text="Đang lấy phí..." android:textColor="#7B5CFA"
        android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <Button android:id="@+id/btnNext" android:text="Tiếp tục" android:textColor="#FFFFFF"
        android:backgroundTint="#7B5CFA" android:layout_marginTop="24dp"
        android:layout_width="match_parent" android:layout_height="48dp"/>
</LinearLayout>
</ScrollView>