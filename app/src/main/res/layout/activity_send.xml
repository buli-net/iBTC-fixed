<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000000" android:orientation="vertical" android:padding="16dp">
    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <ImageView android:id="@+id/btnBack" android:src="@android:drawable/ic_menu_close_clear_cancel" android:tint="#FFF" android:layout_width="24dp" android:layout_height="24dp"/>
        <TextView android:text="Gửi BTC" android:textColor="#FFF" android:textSize="18sp" android:textStyle="bold" android:layout_marginStart="16dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout android:background="#1A1F2E" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:layout_marginTop="24dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <EditText android:id="@+id/etAddress" android:hint="Địa chỉ ví" android:textColorHint="#666" android:textColor="#FFF" android:background="@null" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
        <ImageView android:id="@+id/btnScan" android:src="@android:drawable/ic_menu_camera" android:tint="#7B3FF2" android:layout_width="24dp" android:layout_height="24dp"/>
    </LinearLayout>
    <EditText android:id="@+id/etAmount" android:hint="0.00 BTC" android:textColorHint="#666" android:textColor="#FFF" android:textSize="24sp" android:gravity="center" android:background="#1A1F2E" android:padding="16dp" android:layout_marginTop="16dp" android:inputType="numberDecimal" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <TextView android:text="Phí mạng" android:textColor="#FFF" android:textStyle="bold" android:layout_marginTop="24dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <RadioGroup android:id="@+id/rgFee" android:orientation="vertical" android:layout_marginTop="8dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <RadioButton android:id="@+id/rbSlow" android:text="Chậm" android:textColor="#FFF" android:buttonTint="#7B3FF2" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <RadioButton android:id="@+id/rbNormal" android:text="Thường" android:checked="true" android:textColor="#FFF" android:buttonTint="#7B3FF2" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <RadioButton android:id="@+id/rbFast" android:text="Nhanh" android:textColor="#FFF" android:buttonTint="#7B3FF2" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <RadioButton android:id="@+id/rbCustom" android:text="Tùy chỉnh" android:textColor="#FFF" android:buttonTint="#7B3FF2" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </RadioGroup>
    <EditText android:id="@+id/etCustomFee" android:hint="sat/vB" android:visibility="gone" android:textColor="#FFF" android:textColorHint="#666" android:background="#1A1F2E" android:padding="12dp" android:inputType="number" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvFeeInfo" android:text="≈ 0 sat" android:textColor="#9E9E9E" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btnNext" android:text="Tiếp tục" android:textColor="#FFF" android:backgroundTint="#7B3FF2" android:layout_marginTop="32dp" android:layout_width="match_parent" android:layout_height="48dp"/>
</LinearLayout>