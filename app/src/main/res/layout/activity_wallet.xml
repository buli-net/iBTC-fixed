<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:padding="24dp"
    android:layout_width="match_parent" android:layout_height="match_parent">
    <TextView android:text="Địa chỉ BTC mainnet của bạn:" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvAddress" android:textSize="16sp" android:textIsSelectable="true"
        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
    <TextView android:id="@+id/tvBalance" android:text="Số dư: ..." android:textSize="18sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp"/>
</LinearLayout>