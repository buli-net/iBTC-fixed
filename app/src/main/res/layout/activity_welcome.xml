<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/safepal_bg" android:gravity="center"
    android:orientation="vertical" android:padding="32dp">
    
    <ImageView android:layout_width="80dp" android:layout_height="80dp"
        android:src="@android:drawable/btn_star_big_on" android:tint="@color/safepal_purple"/>
    <TextView android:layout_marginTop="16dp" android:text="iBTC Wallet"
        android:textColor="@color/safepal_text" android:textSize="26sp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:layout_marginTop="8dp" android:text="Ví tự quản lý an toàn"
        android:textColor="@color/safepal_gray"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <Button android:id="@+id/btnCreate" android:layout_width="match_parent"
        android:layout_height="56dp" android:text="Tạo ví mới" android:textAllCaps="false"
        android:backgroundTint="@color/safepal_purple" android:textSize="16sp"/>
    <Button android:id="@+id/btnImport" android:layout_width="match_parent"
        android:layout_height="56dp" android:layout_marginTop="12dp" android:text="Khôi phục ví"
        android:textAllCaps="false" android:backgroundTint="@color/safepal_card2"
        android:textColor="@color/safepal_text"/>
</LinearLayout>