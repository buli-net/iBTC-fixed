<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/safepal_bg" android:gravity="center"
    android:orientation="vertical" android:padding="32dp">

    <TextView android:text="iBTC Wallet" android:textSize="28sp"
        android:textStyle="bold" android:textColor="@color/safepal_purple"
        android:layout_marginBottom="64dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <Button android:id="@+id/btnCreate" android:layout_width="match_parent"
        android:layout_height="56dp" android:text="Tạo ví mới"
        android:backgroundTint="@color/safepal_purple" android:textAllCaps="false"/>

    <Button android:id="@+id/btnImport" android:layout_width="match_parent"
        android:layout_height="56dp" android:layout_marginTop="16dp"
        android:text="Khôi phục ví" android:backgroundTint="@color/safepal_card"
        android:textAllCaps="false"/>
</LinearLayout>