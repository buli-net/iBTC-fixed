<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/safepal_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@android:drawable/ic_lock"
        android:tint="@color/safepal_purple" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="iBTC Wallet"
        android:textColor="@color/safepal_text"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Ví Bitcoin tự quản lý"
        android:textColor="@color/safepal_gray"
        android:textSize="14sp" />

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <Button
        android:id="@+id/btnCreate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="@color/safepal_purple"
        android:text="Tạo ví mới"
        android:textAllCaps="false"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnImport"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/safepal_card"
        android:text="Khôi phục ví (12 từ)"
        android:textAllCaps="false"
        android:textColor="@color/safepal_text"
        android:textSize="16sp" />
</LinearLayout>