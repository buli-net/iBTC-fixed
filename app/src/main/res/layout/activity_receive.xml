<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/safepal_bg" android:gravity="center"
    android:orientation="vertical" android:padding="20dp">
    <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp">
        <ImageView android:id="@+id/btnBack" android:layout_width="24dp" android:layout_height="24dp"
            android:layout_centerVertical="true" android:src="@android:drawable/ic_menu_revert"/>
        <TextView android:layout_centerInParent="true" android:text="Nhận BTC"
            android:textColor="@color/safepal_text" android:textSize="18sp" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </RelativeLayout>
    <WebView android:id="@+id/wvQr" android:layout_marginTop="32dp"
        android:layout_width="200dp" android:layout_height="200dp"/>
    <TextView android:id="@+id/tvAddr" android:layout_marginTop="24dp"
        android:textColor="@color/safepal_text" android:textSize="14sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btnCopy" android:layout_marginTop="16dp"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="@color/safepal_purple" android:text="Sao chép địa chỉ"/>
</LinearLayout>